# HubSpot Private App token (ga naar: Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Geheime sleutel die make.com meegeeft in de X-API-Key header (optioneel maar aanbevolen)
API_KEY=kies_een_geheime_sleutel_hier

# Poort waarop de server draait
PORT=8000
